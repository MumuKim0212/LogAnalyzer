<Window x:Class="LogAnalyzerWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LogAnalyzer WPF" Height="600" Width="1000"
        Background="#1E1E1E" Foreground="#D4D4D4">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <ToolBar Grid.Row="0" Background="#333333" Foreground="#D4D4D4" Margin="0,0,0,5" Padding="5">
            <Button Content="Open Local File" Click="BtnOpenFile_Click" Foreground="White" Background="#282828" BorderBrush="#555" Padding="4,2"/>
            <Button Content="Remote Connect" Click="BtnRemote_Click" Foreground="White" Background="#282828" BorderBrush="#555" Padding="4,2" Margin="5,0"/>
            <Button Content="Local Run (Ctrl+R)" Click="BtnLocalRun_Click" Foreground="White" Background="#282828" BorderBrush="#555" Padding="4,2"/>
            <TextBlock Text="Search:" VerticalAlignment="Center" Margin="15,0,5,0" Foreground="White"/>
            <TextBox x:Name="TxtFilter" Width="200" Margin="5" VerticalAlignment="Center" 
                     TextChanged="TxtFilter_TextChanged" Background="#444444" Foreground="White" BorderBrush="#555"/>
            <CheckBox x:Name="ChkWatch" Content="Autoscroll" Margin="15,0,0,0" Foreground="White" VerticalAlignment="Center" IsChecked="True"/>
        </ToolBar>
        
        <TabControl Grid.Row="1" x:Name="MainTabControl" Background="#1E1E1E" BorderBrush="#333" Foreground="Black">
            <TabItem Header="Logs Viewer" Background="#2D2D30">
                <DataGrid x:Name="LogDataGrid" AutoGenerateColumns="False" 
                          Background="#1E1E1E" RowBackground="#1E1E1E" 
                          AlternatingRowBackground="#252526" Foreground="#D4D4D4" 
                          IsReadOnly="True" GridLinesVisibility="Horizontal" 
                          HorizontalGridLinesBrush="#3E3E42" HeadersVisibility="Column">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#333333"/>
                            <Setter Property="Foreground" Value="#D4D4D4"/>
                            <Setter Property="Padding" Value="5,5,5,5"/>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="{Binding BackgroundColor}" />
                            <Setter Property="Foreground" Value="#D4D4D4" />
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp}" Width="150" />
                        <DataGridTextColumn Header="Level" Binding="{Binding Level}" Width="80" />
                        <DataGridTextColumn Header="Handler" Binding="{Binding Handler}" Width="300" />
                        <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
