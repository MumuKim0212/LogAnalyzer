<Window x:Class="LogAnalyzerWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LogAnalyzer WPF" Height="650" Width="1100"
        Background="#1E1E1E" Foreground="#D4D4D4">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <ToolBar Grid.Row="0" Background="#333333" Foreground="#D4D4D4" Margin="0,0,0,5" Padding="5">
            <Button Content="New Local Tab" Click="BtnOpenFile_Click" Foreground="White" Background="#282828" BorderBrush="#555" Padding="4,2"/>
            <Button Content="New Remote Tab" Click="BtnRemote_Click" Foreground="White" Background="#282828" BorderBrush="#555" Padding="4,2" Margin="5,0"/>
            <Button Content="New Local Run" Click="BtnLocalRun_Click" Foreground="White" Background="#282828" BorderBrush="#555" Padding="4,2"/>
            <Separator Margin="5,0"/>
            <!-- Actions applied to current running tab -->
            <Button Content="Close Tab (Ctrl+W)" Click="BtnCloseTab_Click" Foreground="White" Background="#600000" BorderBrush="#555" Padding="4,2" Margin="5,0"/>
            <Button Content="Toggle Chart (Ctrl+Shift+T)" Click="BtnChart_Click" Foreground="White" Background="#282828" BorderBrush="#555" Padding="4,2" Margin="5,0"/>
            <Separator Margin="5,0"/>
            <TextBlock Text="Search:" VerticalAlignment="Center" Margin="5,0,5,0" Foreground="White"/>
            <TextBox x:Name="TxtFilter" Width="150" Margin="5" VerticalAlignment="Center" 
                     TextChanged="TxtFilter_TextChanged" Background="#444444" Foreground="White" BorderBrush="#555"/>
            <CheckBox x:Name="ChkWatch" Content="Autoscroll" Margin="10,0,0,0" Foreground="White" VerticalAlignment="Center" IsChecked="True" Checked="ChkWatch_Changed" Unchecked="ChkWatch_Changed"/>
        </ToolBar>
        
        <TabControl Grid.Row="1" x:Name="MainTabControl" Background="#1E1E1E" BorderBrush="#333" Foreground="Black" SelectionChanged="MainTabControl_SelectionChanged">
        </TabControl>
    </Grid>
</Window>
